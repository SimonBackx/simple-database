{
    "name": "@simonbackx/simple-database",
    "version": "1.34.0",
    "type": "module",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/esm/index.d.ts"
        },
        "./migrations/*": "./migrations/*"
    },
    "imports": {
        "#migrations/*": "./migrations/*"
    },
    "scripts": {
        "test": "vitest",
        "build": "tsc --build tsconfig.cjs.json tsconfig.esm.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
        "lint": "eslint",
        "prepublishOnly": "vitest && eslint && pnpm build"
    },
    "files": [
        "dist",
        "migrations",
        "package.json"
    ],
    "dependencies": {
        "@simonbackx/simple-logging": "^1.0.0",
        "mysql2": "3.14.1"
    },
    "peerDependencies": {
        "@simonbackx/simple-encoding": "^2.25.0",
        "mysql2": "^3.14.1"
    },
    "devDependencies": {
        "@simonbackx/simple-encoding": "^2.26.0",
        "@simonbackx/simple-errors": "^1.4.0",
        "@types/jest": "^27.0.1",
        "@types/mysql": "^2.15.20",
        "@types/node": "^18.11.17",
        "dotenv": "^10.0.0",
        "eslint-plugin-stamhoofd": "^2.119.0",
        "jest": "^30.3.0",
        "jest-extended": "^7.0.0",
        "oxlint": "^1.56.0",
        "ts-jest": "^29.4.6",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "uuid": "^9.0.0",
        "vitest": "^4.1.0"
    },
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}