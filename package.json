{
    "name": "@simonbackx/simple-database",
    "version": "1.36.4",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./migrations/*": "./migrations/*",
        "./data/*": {
            "import": {
                "types": "./dist/src/classes/data/*.d.mts",
                "default": "./dist/src/classes/data/*.mjs"
            },
            "require": {
                "types": "./dist/src/classes/data/*.d.cts",
                "default": "./dist/src/classes/data/*.cjs"
            }
        }
    },
    "imports": {
        "#migrations/*": "./migrations/*"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "build": "pnpm typecheck && tsdown",
        "lint": "eslint",
        "prepublishOnly": "vitest && eslint --ignore-pattern='**/*.test.ts' && pnpm build"
    },
    "files": [
        "dist",
        "migrations",
        "package.json"
    ],
    "dependencies": {
        "@simonbackx/simple-logging": "^1.0.0",
        "mysql2": "3.14.1"
    },
    "peerDependencies": {
        "@simonbackx/simple-encoding": "^2.25.0",
        "mysql2": "^3.14.1"
    },
    "devDependencies": {
        "@simonbackx/simple-encoding": "^2.26.0",
        "@simonbackx/simple-errors": "^1.4.0",
        "@types/mysql": "^2.15.20",
        "@types/node": "^22.19.15",
        "dotenv": "^10.0.0",
        "eslint-plugin-stamhoofd": "^2.119.0",
        "oxlint": "^1.56.0",
        "tsdown": "^0.21.4",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "uuid": "^9.0.0",
        "vitest": "^4.1.0"
    },
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
