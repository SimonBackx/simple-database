{
    // File used by the editor.
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist"
    },
    "files": [], // intentionally empty
    "include": [
        "./index.ts",
        "./src/**/*.ts",
        "./src/**/*",
    ],
    "exclude": [
        // Tests are excluded (only included in tsconfig.test.json)
        "src/**/*.spec.ts",
        "src/**/*.test.ts"
    ],
    "references": [
        // Project dependencies are added by nx sync
        {
            // Test files
            "path": "./tsconfig.test.json"
        }
    ]
}